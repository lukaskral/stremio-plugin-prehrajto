{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": [
      "ES2022"
    ],
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "noEmit": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "paths": {
      "*": [
        "./node_modules/*",
        "./src/types/*"
      ]
    },
    "skipLibCheck": true,
    "sourceMap": true,
    "target": "ES2018",
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ]
}
